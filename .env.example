# ─────────────────────────────────────────────────────────────────────────────
# SkyView Skyler — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Required — your Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required in production — generate a long random string (e.g. openssl rand -hex 32)
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Set to 'production' when deploying live (enables HTTPS redirect, secure cookies)
FLASK_ENV=development
